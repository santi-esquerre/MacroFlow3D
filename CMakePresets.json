{
    "version": 4,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 23,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "MACROFLOW3D_BUILD_APPS": "ON"
            }
        },
        {
            "name": "wsl-debug",
            "inherits": "base",
            "displayName": "WSL Debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CUDA_ARCHITECTURES": "86",
                "MACROFLOW3D_ENABLE_DIAGNOSTICS": "ON",
                "MACROFLOW3D_ENABLE_PROFILING": "OFF",
                "MACROFLOW3D_ENABLE_NVTX": "OFF",
                "MACROFLOW3D_ENABLE_PETSC": "OFF"
            }
        },
        {
            "name": "wsl-release",
            "inherits": "base",
            "displayName": "WSL Release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CUDA_ARCHITECTURES": "86",
                "MACROFLOW3D_ENABLE_DIAGNOSTICS": "OFF",
                "MACROFLOW3D_ENABLE_PROFILING": "OFF",
                "MACROFLOW3D_ENABLE_NVTX": "OFF",
                "MACROFLOW3D_ENABLE_PETSC": "OFF"
            }
        },
        {
            "name": "wsl-petsc-debug",
            "inherits": "base",
            "displayName": "WSL Debug + PETSc/SLEPc",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CUDA_ARCHITECTURES": "86",
                "MACROFLOW3D_ENABLE_DIAGNOSTICS": "ON",
                "MACROFLOW3D_ENABLE_PROFILING": "OFF",
                "MACROFLOW3D_ENABLE_NVTX": "OFF",
                "MACROFLOW3D_ENABLE_PETSC": "ON",
                "PETSC_DIR": "${sourceDir}/src/external/petsc",
                "PETSC_ARCH": "arch-cuda",
                "SLEPC_DIR": "${sourceDir}/src/external/slepc"
            }
        },
        {
            "name": "v100-release",
            "inherits": "base",
            "displayName": "V100 Release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CUDA_ARCHITECTURES": "70",
                "MACROFLOW3D_ENABLE_DIAGNOSTICS": "OFF",
                "MACROFLOW3D_ENABLE_PROFILING": "ON",
                "MACROFLOW3D_ENABLE_NVTX": "ON",
                "MACROFLOW3D_ENABLE_PETSC": "OFF"
            }
        },
        {
            "name": "v100-prof",
            "inherits": "base",
            "displayName": "V100 RelWithDebInfo + Profiling",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_CUDA_ARCHITECTURES": "70",
                "MACROFLOW3D_ENABLE_DIAGNOSTICS": "OFF",
                "MACROFLOW3D_ENABLE_PROFILING": "ON",
                "MACROFLOW3D_ENABLE_NVTX": "ON",
                "MACROFLOW3D_ENABLE_PETSC": "OFF"
            }
        },
        {
            "name": "v100-petsc",
            "inherits": "base",
            "displayName": "V100 Release + PETSc/SLEPc",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CUDA_ARCHITECTURES": "70",
                "MACROFLOW3D_ENABLE_DIAGNOSTICS": "OFF",
                "MACROFLOW3D_ENABLE_PROFILING": "ON",
                "MACROFLOW3D_ENABLE_NVTX": "ON",
                "MACROFLOW3D_ENABLE_PETSC": "ON",
                "PETSC_DIR": "${sourceDir}/src/external/petsc",
                "PETSC_ARCH": "arch-cuda",
                "SLEPC_DIR": "${sourceDir}/src/external/slepc"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "wsl-debug",
            "configurePreset": "wsl-debug",
            "jobs": 0
        },
        {
            "name": "wsl-release",
            "configurePreset": "wsl-release",
            "jobs": 0
        },
        {
            "name": "wsl-petsc-debug",
            "configurePreset": "wsl-petsc-debug",
            "jobs": 0
        },
        {
            "name": "v100-release",
            "configurePreset": "v100-release",
            "jobs": 0
        },
        {
            "name": "v100-prof",
            "configurePreset": "v100-prof",
            "jobs": 0
        },
        {
            "name": "v100-petsc",
            "configurePreset": "v100-petsc",
            "jobs": 0
        }
    ],
    "testPresets": [
        {
            "name": "wsl-debug",
            "configurePreset": "wsl-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "wsl-petsc-debug",
            "configurePreset": "wsl-petsc-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "wsl-release",
            "configurePreset": "wsl-release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "v100-release",
            "configurePreset": "v100-release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "v100-prof",
            "configurePreset": "v100-prof",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "v100-petsc",
            "configurePreset": "v100-petsc",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
